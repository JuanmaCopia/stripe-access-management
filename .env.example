# Shared development environment example
#
# Copy this file to `.env` before running local database commands.

POSTGRES_DB=stripe_access_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stripe_access_management?schema=public

# Stripe catalog setup for the MVP subscription matrix
STRIPE_STARTER_PRODUCT_ID=prod_starter_placeholder
STRIPE_STARTER_MONTHLY_PRICE_ID=price_starter_monthly_placeholder
STRIPE_STARTER_YEARLY_PRICE_ID=price_starter_yearly_placeholder
STRIPE_PRO_PRODUCT_ID=prod_pro_placeholder
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly_placeholder
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_placeholder
STRIPE_ULTRA_PRODUCT_ID=prod_ultra_placeholder
STRIPE_ULTRA_MONTHLY_PRICE_ID=price_ultra_monthly_placeholder
STRIPE_ULTRA_YEARLY_PRICE_ID=price_ultra_yearly_placeholder
